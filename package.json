{
  "name": "trinacria-hub",
  "version": "1.0.0",
  "description": "Trinacria Hub - E-commerce di Abbigliamento di Lusso",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
