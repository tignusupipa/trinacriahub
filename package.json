    "start": "cd frontend && npm start"
  },
  "devDependencies": {
    "concurrently": "^7.6.0"
  },
  "keywords": [
    "ecommerce",
    "fashion",
    "luxury",
    "react",
    "fastapi"
  ],
  "author": "Trinacria Hub",
